    "X_test[\"OWN_REALTY\"] = X_test[\"FLAG_OWN_REALTY\"].map({\"N\": 0, \"Y\": 1})\n",
    "X_test[\"OWN_CAR\"] = X_test[\"FLAG_OWN_CAR\"].map({\"N\": 0, \"Y\": 1})\n",
