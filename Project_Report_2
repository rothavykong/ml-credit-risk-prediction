    "# Step 6 — Combine all encoded parts\n",
    "X_train_final = pd.concat([num_cols_train, encoded_df_1, encoded_df_2], axis=1)\n",
    "X_test_final = pd.concat([num_cols_test, encoded_df_1_test, encoded_df_2_test], axis=1)\n",
    "\n",
